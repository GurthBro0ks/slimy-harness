{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SlimyAI Session Report",
  "description": "Schema for agent session reports written at shutdown by the self-sequencing layer.",
  "type": "object",
  "required": [
    "session_id",
    "agent",
    "nuc",
    "project",
    "feature_id",
    "prompt_type",
    "status",
    "summary",
    "changes",
    "tests",
    "blockers",
    "recommendation",
    "kb_learnings",
    "duration_minutes",
    "timestamp"
  ],
  "properties": {
    "report_schema_version": {
      "type": "string",
      "enum": ["2"],
      "description": "Projection schema version for evidence-rich proof reports."
    },
    "session_id": {
      "type": "string",
      "description": "ISO-8601 timestamp used as unique session identifier.",
      "format": "date-time"
    },
    "agent": {
      "type": "string",
      "enum": ["claude", "claude-code", "codex", "manual", "minimax", "opencode"],
      "description": "Which agent type produced this session."
    },
    "nuc": {
      "type": "string",
      "enum": ["nuc1", "nuc2"],
      "description": "Which NUC this session ran on."
    },
    "project": {
      "type": "string",
      "description": "Repo name the agent worked on."
    },
    "feature_id": {
      "type": ["string", "null"],
      "description": "Feature ID from feature_list.json, or null if ad-hoc work."
    },
    "prompt_type": {
      "type": "string",
      "enum": ["A", "B", "C", "C2", "D", "E", "F", "G", "H", "I", "P", "direct"],
      "description": "Which prompt type was used for this session."
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "WARN", "FAIL", "completed", "partial", "failed", "blocked", "pass", "warn", "fail"],
      "description": "Final status of the session."
    },
    "result": {
      "type": "string",
      "description": "Canonical RESULT.md verdict when present."
    },
    "summary": {
      "type": "string",
      "description": "1-2 sentence summary of what was done."
    },
    "changes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of files changed during the session."
    },
    "tests": {
      "type": "object",
      "required": ["ran", "passed"],
      "properties": {
        "ran": {
          "type": "boolean",
          "description": "Whether tests were run."
        },
        "passed": {
          "type": "boolean",
          "description": "Whether all tests passed."
        },
        "details": {
          "type": "string",
          "description": "Truth gate output summary."
        },
        "label": {
          "type": "string",
          "enum": ["TESTS PASS", "TESTS FAIL", "TESTS NOT RUN", "SMOKE ONLY"],
          "description": "Display label for report UIs. Smoke-only or not-run validation must not be labeled as TESTS FAIL."
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "status", "display", "source_artifact"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "status": { "type": "string", "enum": ["PASS", "FAIL"] },
              "passed": { "type": ["integer", "null"], "minimum": 0 },
              "failed": { "type": ["integer", "null"], "minimum": 0 },
              "total": { "type": ["integer", "null"], "minimum": 0 },
              "display": { "type": "string" },
              "source_artifact": { "type": "string" }
            }
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["manual", "dependency", "bug", "question"],
            "description": "Category of blocker."
          },
          "description": {
            "type": "string",
            "description": "What is blocking progress."
          },
          "blocks_feature": {
            "type": ["string", "null"],
            "description": "Feature ID this blocks, or null."
          }
        }
      },
      "description": "Active blockers encountered during the session."
    },
    "recommendation": {
      "type": "object",
      "required": ["next_feature_id", "reasoning"],
      "properties": {
        "next_feature_id": {
          "type": ["string", "null"],
          "description": "Suggested next feature ID, or null."
        },
        "reasoning": {
          "type": "string",
          "description": "Why this feature should be next."
        },
        "risk_notes": {
          "type": "string",
          "description": "Any caution for the next session."
        }
      }
    },
    "kb_learnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "New knowledge worth capturing for the KB."
    },
    "duration_minutes": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "Evidence-backed session duration in minutes, or null when unknown."
    },
    "duration_source": {
      "type": "string",
      "description": "Evidence used to compute duration."
    },
    "started_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "validation_summary": {
      "type": "string"
    },
    "artifacts": {
      "type": "object",
      "required": ["proof_files_total", "displayed_count", "displayed_files", "filter_explanation"],
      "properties": {
        "directory_files_total": { "type": "integer", "minimum": 0 },
        "proof_files_total": { "type": "integer", "minimum": 0 },
        "displayed_count": { "type": "integer", "minimum": 0 },
        "displayed_files": { "type": "array", "items": { "type": "string" } },
        "excluded_count": { "type": "integer", "minimum": 0 },
        "excluded_files": { "type": "array", "items": { "type": "string" } },
        "filter_explanation": { "type": "string" }
      }
    },
    "next_action": {
      "type": "string"
    },
    "run_id": {
      "type": ["string", "null"]
    },
    "subject_id": {
      "type": ["string", "null"]
    },
    "pushed": {
      "type": ["boolean", "null"]
    },
    "production_storage_state": {
      "type": "string",
      "enum": ["active", "inactive", "unknown"]
    },
    "underlying_functional_qa": {
      "type": ["string", "null"]
    },
    "manual_qa_status": {
      "type": ["string", "null"]
    },
    "operator_qa": {
      "type": ["string", "null"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when session ended."
    }
  }
}
