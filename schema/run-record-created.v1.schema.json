{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness.slimyai.xyz/schema/run-record-created.v1.schema.json",
  "title": "Slimy Harness immutable run creation record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "v", "schema_id", "record_type", "sequence", "run_id",
    "subject_type", "subject_id", "project_id", "repository", "machine",
    "actor", "authority", "created_at", "payload_sha256"
  ],
  "properties": {
    "v": { "const": 1 },
    "schema_id": { "const": "slimy-harness.run-created.v1" },
    "record_type": { "const": "CREATED" },
    "sequence": { "const": 1 },
    "run_id": { "type": "string", "pattern": "^run_[0-9]{8}T[0-9]{12}Z_[0-9a-f]{32}$" },
    "subject_type": { "enum": ["run", "feature", "policy", "waiver", "document", "deviation", "repository"] },
    "subject_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "project_id": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "remote_url", "head_sha"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "remote_url": { "type": "string", "minLength": 1 },
        "head_sha": { "type": "string", "pattern": "^[0-9a-f]{40}([0-9a-f]{24})?$" }
      }
    },
    "machine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "hostname"],
      "properties": {
        "id": { "enum": ["nuc1", "nuc2"] },
        "hostname": { "type": "string", "minLength": 1, "maxLength": 253 }
      }
    },
    "actor": { "type": "string", "minLength": 1, "maxLength": 128 },
    "authority": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "created_at": { "type": "string", "format": "date-time" },
    "payload_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "subject_type": { "const": "repository" } },
        "required": ["subject_type"]
      },
      "then": {
        "properties": {
          "subject_id": {
            "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?@[0-9a-f]{40}([0-9a-f]{24})?$"
          }
        }
      }
    }
  ]
}
