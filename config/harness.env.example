# Harness Env Example
#
# Copy this file to /home/slimy/.slimy-harness.env and fill in real values.
# /home/slimy/.slimy-harness.env is OUTSIDE the slimy-harness repo and is
# NEVER committed (see .gitignore in /home/slimy/.gitignore_global).
#
# DO NOT commit real webhook URLs or tokens. Use a placeholder during dev.

# --- Discord completion webhook ---------------------------------------------
# Webhook used by sequencer/notify-session-complete.sh when an agent run ends.
# Create one in Discord: Channel Settings -> Integrations -> Webhooks.
DISCORD_HARNESS_WEBHOOK_URL=

# Mention string injected into the completion message on WARN/FAIL/BLOCKED,
# and on SUCCESS when HARNESS_NOTIFY_ON_SUCCESS=1 or
# HARNESS_NOTIFY_PING_ON_SUCCESS=1. The numeric user id is also extracted
# for Discord's allowed_mentions so the mention actually pings.
# Use a Discord user/role mention like <@427999592986968074> or <@&ROLE_ID>.
DISCORD_HARNESS_MENTION=<@427999592986968074>

# --- Public report URLs -----------------------------------------------------
# Base URL where session-report HTML/JSON is rendered. Owner-gated.
# Defaults to https://harness.slimyai.xyz when unset.
HARNESS_REPORT_BASE_URL=https://harness.slimyai.xyz

# --- Notification behaviour -------------------------------------------------
# Default mode: clean link-only Discord message with one embed card and
# NO attachments. The report URL is the full Owner-gated HTML report.
#
# Mention on success as well as WARN/FAIL/BLOCKED. 1 = on, 0 = off.
HARNESS_NOTIFY_ON_SUCCESS=1
# Alternative ping-on-success flag (equivalent to HARNESS_NOTIFY_ON_SUCCESS).
HARNESS_NOTIFY_PING_ON_SUCCESS=1
# Attach rendered HTML snapshot to the Discord message. 1 = on, 0 = off.
# Default 0 (clean link-only). Set to 1 only if the channel prefers an
# in-line attachment over the clickable report URL.
HARNESS_NOTIFY_ATTACH_HTML=0
# Attach the raw session-report.json. 1 = on, 0 = off. Default 0.
HARNESS_NOTIFY_ATTACH_JSON=0
